{
  "manifest_version": 3,
  "name": "LLM Safety Guard",
  "version": "1.0",
  "description": "Scans input for unsafe text.",
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "LLM Safety Settings"
  },
  "permissions": ["storage", "alarms", "offscreen"],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'none'; worker-src 'self';"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["platforms.js", "content.js"]
    }
  ],

  "web_accessible_resources": [{
    "resources": [
      "model/*",
      "lib/*",
      "rules.json",
      "offscreen2.html",
      "offscreen_bundle.js"
    ],
    "matches": ["<all_urls>"]
  }]
}